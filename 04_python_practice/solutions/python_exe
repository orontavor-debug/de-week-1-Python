def mask_email(s):
    parts = s.split("@")
    user = parts[0]
    rest = parts[1]
    domain_parts = rest.split(".")
    domain = domain_parts[0]
    tld = domain_parts[1]
    #print(user, domain, tld)
    masked_user=user[0] + "*" * len(user[1:])
    masked_domain=domain[0] + "*" * len(domain[1:])
    return masked_user + "@" + masked_domain + "." + tld

