def group_by(xs, key_fn):
    result = {}
    for word in xs:
        group = key_fn(word)
        if group not in result:
            result[group] = []
        result[group].append(word)
    return result

print(group_by(["apple", "pear", "plum", "kiwi"], len))

###merge function
#1. function is getting 2 dicts -  base and override
#2. create result dict
#3. loop over base list, for each key, check if it has an identical key in the override list. if yes, store the key:value from override in a new result dict. if not, store in result the key:value that appears in base

def merge_priority(base, override):
    result = {}
    for key,value in base.items():
        if key in override:
            result[key] = override[key]
        else:
            result[key] = value
    for key,value in override.items():
        if key not in result:
            result[key]= value
    return result

print(merge_priority({"a":1, "b":2}, {"b":9, "c":3}))